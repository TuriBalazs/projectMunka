<Window x:Class="projectMunka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:projectMunka"
        mc:Ignorable="d"
        Title="MainWindow" Height="auto" Width="auto" MinHeight="450" MinWidth="800" WindowState="Maximized">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <DataGrid x:Name="datagridUsers"  AutoGenerateColumns="False" IsReadOnly="True" ColumnWidth="*" Grid.ColumnSpan="3">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Vezetéknév"/>
                <DataGridTextColumn Header="Keresztnév"/>
                <DataGridTextColumn Header="E-mail cím"/>
                <DataGridTextColumn Header="Telefonszám" />
                <DataGridTextColumn Header="Életkor" />
                <DataGridTemplateColumn Header="Kép">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Image />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>
        <Button x:Name="buttonKeres" Content="Keresés" FontSize="20" Width="200" Height="40" Grid.Row="1" Grid.Column="0" />
        <Button x:Name="buttonModosit" Content="Módosítás" FontSize="20" Width="200" Height="40" Grid.Row="1" Grid.Column="1" />
        <Button x:Name="buttonFeltolt" Content="Feltöltés" FontSize="20" Width="200" Height="40" Grid.Row="1" Grid.Column="2"  />
    </Grid>
</Window>
